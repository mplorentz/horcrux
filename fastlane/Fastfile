# Fastfile for Horcrux iOS and Android Distribution
# Documentation: https://docs.fastlane.tools

# Load environment variables from .env file
require 'dotenv'

Dotenv.load

# Helper method to get App Store Connect API key using standard fastlane env vars
# Standard fastlane environment variables:
# - APP_STORE_KEY_ID
# - APP_STORE_ISSUER_ID  
# - APP_STORE_KEY_FILEPATH
def get_api_key
  if ENV["APP_STORE_KEY_FILEPATH"]
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_FILEPATH"],
      duration: 1200,
      in_house: false
    )
  else
    nil
  end
end

# Helper method to get Google Play service account JSON key filepath.
# Reads GOOGLE_PLAY_JSON_KEY_PATH (preferred) or GOOGLE_PLAY_SERVICE_ACCOUNT_JSON.
# This is NOT the Firebase google-services.json — it's a service account key
# downloaded from Google Cloud Console with Play Developer API access.
def get_google_play_json_key
  ENV["GOOGLE_PLAY_JSON_KEY_PATH"] || ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_JSON"]
end

def read_pubspec_version_string
  pubspec_path = File.expand_path("../pubspec.yaml", __dir__)
  pubspec_content = File.read(pubspec_path)
  m = pubspec_content.match(/^version:\s*(.+)$/)
  UI.user_error!("Could not parse version from pubspec.yaml") unless m
  m[1].strip
end

# Default platform (needed for iOS actions in top-level lanes like set_version)
default_platform(:ios)

private_lane :ios_increment_build_sync_pubspec do
  increment_build_number(
    xcodeproj: "ios/Runner.xcodeproj"
  )

  current_version = get_version_number(xcodeproj: "ios/Runner.xcodeproj")
  build_number = get_build_number(xcodeproj: "ios/Runner.xcodeproj")

  pubspec_path = File.expand_path("../pubspec.yaml", __dir__)
  pubspec_content = File.read(pubspec_path)
  new_version = "#{current_version}+#{build_number}"
  pubspec_content.gsub!(/^version: .*$/, "version: #{new_version}")
  File.write(pubspec_path, pubspec_content)

  UI.success("✅ Build number bumped to #{build_number}")
  UI.success("✅ Updated pubspec.yaml version to #{new_version}")
end

desc "Set marketing version on iOS, bump build once, sync pubspec (Flutter/Android versionCode + versionName)"
desc "Usage: fastlane set_version version:0.8.0 — or VERSION=0.8.0"
lane :set_version do |options|
  new_version = (options[:version] || ENV["VERSION"]).to_s.strip
  UI.user_error!("Provide version: X.Y.Z — e.g. fastlane set_version version:0.8.0") if new_version.empty?

  increment_version_number(
    version_number: new_version,
    xcodeproj: "ios/Runner.xcodeproj"
  )

  ios_increment_build_sync_pubspec
  UI.success("✅ set_version complete — iOS + pubspec (Android) aligned")
end

desc "Bump build once (iOS CFBundleVersion + pubspec; Android uses pubspec), then ship everywhere"
desc "Chains: ios_beta → android_beta → android_github_prerelease. From repo root: bundle exec fastlane ship_beta_all"
desc "Needs: App Store API key (.env), GOOGLE_PLAY_JSON_KEY_PATH, GITHUB_REPOSITORY + GITHUB_TOKEN (or GH_TOKEN)"
lane :ship_beta_all do
  ios_increment_build_sync_pubspec

  project_root = File.expand_path("..", __dir__)
  Dir.chdir(project_root) do
    sh("bundle exec fastlane ios ios_beta")
    sh("bundle exec fastlane android android_beta")
    sh("bundle exec fastlane android android_github_prerelease")
  end

  UI.success("✅ ship_beta_all complete — TestFlight, Play internal, GitHub APK pre-release")
end

platform :ios do
  desc "Sync code signing certificates using API key"
  lane :sync_certs do
    api_key_obj = get_api_key
    if api_key_obj
      match(
        type: "appstore",
        readonly: false,
        api_key: api_key_obj
      )
    else
      UI.user_error!("API key not configured. Set APP_STORE_CONNECT_API_KEY_KEY_FILEPATH, APP_STORE_CONNECT_API_KEY_KEY_ID, and APP_STORE_CONNECT_API_KEY_ISSUER_ID in .env")
    end
  end

  desc "Build and upload iOS beta to TestFlight"
  lane :ios_beta do
    # Sync certificates and provisioning profiles
    api_key_obj = get_api_key
    match(
      type: "appstore",
      readonly: false,
      api_key: api_key_obj
    )
    
    project_root = File.expand_path("..", __dir__)

    # Clean build from scratch. This is required (not just tidy): iOS Simulator
    # builds leave IOSSIMULATOR-tagged FFI frameworks (rust_lib_ndk, objective_c)
    # in build/native_assets/ios, which App Store Connect rejects. Manually
    # deleting that directory does NOT work because Flutter's incremental build
    # stamps stay valid, so the native assets never get regenerated. flutter clean
    # invalidates those stamps and guarantees fresh device frameworks.
    sh("cd #{project_root} && flutter clean")
    sh("cd #{project_root} && flutter pub get")

    # Install CocoaPods dependencies (pub get regenerates Generated.xcconfig first)
    podfile_path = File.expand_path("../ios/Podfile", __dir__)
    cocoapods(
      podfile: podfile_path,
      try_repo_update_on_error: true
    )

    # Build the iOS app using Flutter
    sh("cd #{project_root} && flutter build ipa --release")
    
    # Find the IPA file
    ipa_path = File.expand_path("../build/ios/ipa/*.ipa", __dir__)
    ipa_files = Dir[ipa_path]
    
    if ipa_files.empty?
      UI.user_error!("IPA file not found. Build may have failed.")
    end
    
    ipa_file = ipa_files.first
    
    # Upload to TestFlight
    api_key_obj = get_api_key
    upload_to_testflight(
      ipa: ipa_file,
      api_key: api_key_obj,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: false,
      notify_external_testers: false,
      uses_non_exempt_encryption: false
    )
    
    UI.success("✅ iOS beta uploaded to TestFlight")
  end

  desc "Bump build number only"
  lane :bump_build do
    ios_increment_build_sync_pubspec
  end

  desc "Bump patch version (1.0.0 → 1.0.1)"
  lane :bump_patch do
    # Get current version
    current_version = get_version_number(xcodeproj: "ios/Runner.xcodeproj")
    version_parts = current_version.split(".")
    major = version_parts[0].to_i
    minor = version_parts[1].to_i
    patch = version_parts[2].to_i
    
    # Increment patch
    new_version = "#{major}.#{minor}.#{patch + 1}"
    
    # Update version in Xcode project
    increment_version_number(
      version_number: new_version,
      xcodeproj: "ios/Runner.xcodeproj"
    )
    
    # Reset build number to 1
    increment_build_number(
      build_number: "1",
      xcodeproj: "ios/Runner.xcodeproj"
    )
    
    build_number = get_build_number(xcodeproj: "ios/Runner.xcodeproj")
    
    # Update pubspec.yaml
    pubspec_path = File.expand_path("../pubspec.yaml", __dir__)
    pubspec_content = File.read(pubspec_path)
    new_version_string = "#{new_version}+#{build_number}"
    pubspec_content.gsub!(/^version: .*$/, "version: #{new_version_string}")
    File.write(pubspec_path, pubspec_content)
    
    UI.success("✅ Version bumped to #{new_version_string}")
  end

  desc "Bump minor version (1.0.0 → 1.1.0)"
  lane :bump_minor do
    current_version = get_version_number(xcodeproj: "ios/Runner.xcodeproj")
    version_parts = current_version.split(".")
    major = version_parts[0].to_i
    minor = version_parts[1].to_i
    
    new_version = "#{major}.#{minor + 1}.0"
    
    increment_version_number(
      version_number: new_version,
      xcodeproj: "ios/Runner.xcodeproj"
    )
    
    increment_build_number(
      build_number: "1",
      xcodeproj: "ios/Runner.xcodeproj"
    )
    
    build_number = get_build_number(xcodeproj: "ios/Runner.xcodeproj")
    
    pubspec_path = File.expand_path("../pubspec.yaml", __dir__)
    pubspec_content = File.read(pubspec_path)
    new_version_string = "#{new_version}+#{build_number}"
    pubspec_content.gsub!(/^version: .*$/, "version: #{new_version_string}")
    File.write(pubspec_path, pubspec_content)
    
    UI.success("✅ Version bumped to #{new_version_string}")
  end

  desc "Bump major version (1.0.0 → 2.0.0)"
  lane :bump_major do
    current_version = get_version_number(xcodeproj: "ios/Runner.xcodeproj")
    version_parts = current_version.split(".")
    major = version_parts[0].to_i
    
    new_version = "#{major + 1}.0.0"
    
    increment_version_number(
      version_number: new_version,
      xcodeproj: "ios/Runner.xcodeproj"
    )
    
    increment_build_number(
      build_number: "1",
      xcodeproj: "ios/Runner.xcodeproj"
    )
    
    build_number = get_build_number(xcodeproj: "ios/Runner.xcodeproj")
    
    pubspec_path = File.expand_path("../pubspec.yaml", __dir__)
    pubspec_content = File.read(pubspec_path)
    new_version_string = "#{new_version}+#{build_number}"
    pubspec_content.gsub!(/^version: .*$/, "version: #{new_version_string}")
    File.write(pubspec_path, pubspec_content)
    
    UI.success("✅ Version bumped to #{new_version_string}")
  end
end

platform :android do
  desc "Build Android APK for distribution outside Google Play"
  lane :build_apk do
    sh("cd .. && flutter build apk --split-per-abi --release")
    UI.success("✅ APK built successfully")
    UI.message("📦 APK location: build/app/outputs/flutter-apk/")
    
    # List the generated APKs
    apk_dir = File.expand_path("../build/app/outputs/flutter-apk", __dir__)
    if Dir.exist?(apk_dir)
      apks = Dir.glob("#{apk_dir}/*.apk")
      if apks.any?
        UI.message("Generated APKs:")
        apks.each { |apk| UI.message("  - #{File.basename(apk)}") }
      end
    end
  end

  desc "Build and upload Android beta to Google Play Console (Internal Testing)"
  lane :android_beta do
    json_key_path = get_google_play_json_key
    if json_key_path.nil? || json_key_path.to_s.strip.empty?
      UI.user_error!(<<~MSG)
        Google Play service account JSON key not configured.
        Set GOOGLE_PLAY_JSON_KEY_PATH in .env to an absolute path of the
        service account JSON downloaded from Google Cloud Console.
        See: https://docs.fastlane.tools/getting-started/android/setup/#collect-your-google-credentials
        Note: this is NOT android/app/google-services.json (Firebase config).
      MSG
    end

    unless File.exist?(json_key_path)
      UI.user_error!("Google Play service account JSON key file not found at: #{json_key_path}")
    end
    
    # Build Android App Bundle
    sh("cd .. && flutter build appbundle --release")
    
    # Upload to Google Play Console Internal Testing track
    aab_path = File.expand_path("../build/app/outputs/bundle/release/app-release.aab", __dir__)
    upload_to_play_store(
      package_name: "com.singleoriginsoftware.horcrux",
      json_key: json_key_path,
      track: "internal",
      aab: aab_path,
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
    
    UI.success("✅ Android beta uploaded to Google Play Console Internal Testing")
  end

  desc "Build release APK and publish to GitHub Releases as a pre-release (uploads app-release.apk)"
  desc "Uses fastlane built-in set_github_release. Requires GITHUB_TOKEN (or GH_TOKEN) and GITHUB_REPOSITORY=owner/repo. Optional: GITHUB_PRERELEASE_TAG, GITHUB_RELEASE_NAME, GITHUB_RELEASE_BODY. SKIP_BUILD=true skips flutter build. Duplicate tag: delete the release or choose a new tag (built-in action does not attach assets to an existing release)."
  lane :android_github_prerelease do
    skip_build = ENV["SKIP_BUILD"].to_s == "true"
    unless skip_build
      sh("cd .. && flutter build apk --release")
    end

    apk_path = File.expand_path("../build/app/outputs/flutter-apk/app-release.apk", __dir__)
    unless File.exist?(apk_path)
      UI.user_error!("APK not found at #{apk_path}. Build first or run without SKIP_BUILD.")
    end

    repository_name = (ENV["GITHUB_REPOSITORY"] || ENV["GITHUB_REPO"]).to_s.strip
    UI.user_error!("Set GITHUB_REPOSITORY to owner/repo (no URL)") if repository_name.empty?
    UI.user_error!("Use owner/repo only, not a full GitHub URL") if repository_name.include?("github.com")

    repo_parts = repository_name.split("/")
    UI.user_error!("GITHUB_REPOSITORY must be exactly owner/repo") unless repo_parts.length == 2 && repo_parts.none?(&:empty?)

    token = (ENV["GITHUB_TOKEN"] || ENV["GH_TOKEN"]).to_s.strip
    UI.user_error!("Set GITHUB_TOKEN or GH_TOKEN (contents:write / repo scope)") if token.empty?

    # GitHub Actions GITHUB_TOKEN expects Bearer auth; PAT uses api_token path in fastlane.
    github_auth = ENV["GITHUB_ACTIONS"] == "true" ? { api_bearer: token } : { api_token: token }

    version_string = read_pubspec_version_string
    tag = (ENV["GITHUB_PRERELEASE_TAG"] || "").strip
    tag = "v#{version_string.tr('+', '-')}" if tag.empty?

    release_name = (ENV["GITHUB_RELEASE_NAME"] || "").strip
    release_name = "Horcrux #{version_string} (pre-release)" if release_name.empty?

    release_body = (ENV["GITHUB_RELEASE_BODY"] || "").strip
    release_body = "Android APK pre-release for #{version_string}." if release_body.empty?

    release = set_github_release(
      repository_name: repository_name,
      tag_name: tag,
      name: release_name,
      description: release_body,
      is_prerelease: true,
      upload_assets: [apk_path],
      **github_auth
    )

    if release.nil?
      UI.user_error!("GitHub release failed (duplicate tag #{tag} or API error—see logs; delete the release or set GITHUB_PRERELEASE_TAG)")
    end

    UI.success("✅ Published GitHub pre-release #{tag}")
    UI.success("🔗 #{release['html_url']}") if release["html_url"]
  end

  desc "Bump Android build number only"
  lane :bump_build do
    pubspec_path = File.expand_path("../pubspec.yaml", __dir__)
    pubspec_content = File.read(pubspec_path)
    version_match = pubspec_content.match(/^version: (.+)$/)
    
    if version_match
      version_string = version_match[1]
      version_parts = version_string.split("+")
      version_name = version_parts[0]
      version_code = version_parts[1].to_i
      
      new_version_code = version_code + 1
      new_version_string = "#{version_name}+#{new_version_code}"
      
      pubspec_content.gsub!(/^version: .*$/, "version: #{new_version_string}")
      File.write(pubspec_path, pubspec_content)
      
      UI.success("✅ Build number bumped to #{new_version_code}")
      UI.success("✅ Updated pubspec.yaml version to #{new_version_string}")
    else
      UI.user_error!("Could not find version in pubspec.yaml")
    end
  end
end

